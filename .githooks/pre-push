#!/usr/bin/env bash
set -euo pipefail

# Pre-push: eval tests (fast, ~15s)
# Full validate (host builds) runs in CI, not here
echo "=== Checking formatting ==="
nix fmt -- --fail-on-change || {
  echo "Formatting issues. Run: nix fmt"
  exit 1
}

echo "=== Eval tests ==="
for check in eval-hostspec-defaults eval-scope-activation eval-org-defaults; do
  nix build ".#checks.x86_64-linux.$check" --no-link 2>/dev/null || {
    echo "Eval test $check failed."
    exit 1
  }
done

echo "All pre-push checks passed."
